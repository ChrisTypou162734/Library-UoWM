# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=uowm_library

# ── Firebase (προαιρετικό — αφήστε κενό για local storage) ───────────────────
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# ── Server ────────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://library.uowm.gr

# ── Auth ──────────────────────────────────────────────────────────────────────
# Τυχαίο secret — αλλάξτε το σε production
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-string

# Admin credentials
ADMIN_USERNAME=admin
# Δημιουργήστε hash: python scripts/gen_password.py yourpassword
ADMIN_PASSWORD_HASH=$2b$12$nm1VsrLLaGvrVzW4JBebSOXdUpUOhXMeg6Qk1tRgObbK24exQGimO